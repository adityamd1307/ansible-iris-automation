# --- Secrets: never commit ---
.env
*.key
*.ISCkey
iris.key

# Encrypted vault holds real credentials; the *.example.yml template is OK.
group_vars/vault.yml
**/vault.yml
!*.example.yml

# --- Docker-compose durable volume mounts (runtime data) ---
irisa/
irisb/
webgatewaya/
webgatewayb/
arbiter/
/haproxy/

# Keep the small Web Gateway config files used by iris-env docker-compose.
!iris-env/
!iris-env/IRISSystemManagement/
!iris-env/IRISSystemManagement/webgatewaya/
iris-env/IRISSystemManagement/webgatewaya/*
!iris-env/IRISSystemManagement/webgatewaya/CSP.ini
!iris-env/IRISSystemManagement/webgatewaya/CSP.conf
!iris-env/IRISSystemManagement/webgatewayb/
iris-env/IRISSystemManagement/webgatewayb/*
!iris-env/IRISSystemManagement/webgatewayb/CSP.ini
!iris-env/IRISSystemManagement/webgatewayb/CSP.conf

# --- Staged security sync XML (sensitive) ---
stage_dir/security-sync/
**/iris_security_*.xml

# --- Captured run artifacts (keep the folder, ignore its output) ---
evidence/*.log
evidence/*.json
evidence/*.txt
evidence/demo-notes.md
!evidence/README.md
!evidence/.gitkeep
