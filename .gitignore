# --- Secrets: never commit ---
.env
*.key
iris.key

# Encrypted vault holds real credentials; the *.example.yml template is OK.
group_vars/vault.yml
**/vault.yml
!*.example.yml

# --- Docker-compose durable volume mounts (runtime data) ---
irisa/
irisb/
webgatewaya/
webgatewayb/
arbiter/
haproxy/

# --- Staged security sync XML (sensitive) ---
stage_dir/security-sync/
**/iris_security_*.xml

# --- Captured run artifacts (keep the folder, ignore its output) ---
evidence/*.log
evidence/*.json
evidence/*.txt
!evidence/README.md
!evidence/.gitkeep
