; =====================================================================
; Guarded / idempotent interoperability production auto-start
; =====================================================================
; Rendered by playbooks/setup_production.yml. Runs INSIDE the interop
; namespace and configures the auto-start production via Ens.Director.
;
; This is done via ObjectScript (not CPF) because auto-start is an
; operational API setting. It is guarded: the current setting is checked
; first and only changed if different. Wrapped in try/catch so a
; non-interop namespace (or missing production class) skips cleanly
; instead of failing the run. Auto-start is configured on the mirror
; primary only; journaled namespace globals replicate to the backup.
;
; Each executable line is a SINGLE complete statement (the whole guarded
; try/catch is on one line): `iris session` reads stdin as a terminal
; REPL and cannot continue a { } block across input lines.
write !, "--- PRODUCTION SETUP ---"
{% if production.auto_start | default(false) %}
try { zn "{{ namespace }}" set hasEns=##class(%Dictionary.CompiledClass).%ExistsId("Ens.Director") if 'hasEns { write !,"SKIP interop-not-enabled-or-missing-class: Ens.Director absent" } else { set desired="{{ production.class }}" set cur=##class(Ens.Director).GetActiveProductionName() if cur'=desired { set sc=##class(Ens.Director).SetAutoStart(desired) write !,"SET AUTOSTART "_desired_" sc="_$system.Status.GetErrorText(sc) } else { write !,"EXISTS AUTOSTART "_desired } {% if mirror_role | default('') == 'primary' %} if '##class(Ens.Director).IsProductionRunning() { set sc=##class(Ens.Director).StartProduction(desired) write !,"START PRODUCTION "_desired_" sc="_$system.Status.GetErrorText(sc) } else { write !,"EXISTS RUNNING PRODUCTION "_desired }{% endif %} } } catch e { write !,"SKIP interop-not-enabled-or-missing-class: "_e.DisplayString() }
{% else %}
try { zn "{{ namespace }}" set hasEns=##class(%Dictionary.CompiledClass).%ExistsId("Ens.Director") if 'hasEns { write !,"SKIP interop-not-enabled-or-missing-class: Ens.Director absent" } else { set cur=##class(Ens.Director).GetActiveProductionName() if cur'="" { set sc=##class(Ens.Director).SetAutoStart("") write !,"CLEARED AUTOSTART was "_cur } else { write !,"EXISTS no-autostart" } } } catch e { write !,"SKIP interop-not-enabled-or-missing-class: "_e.DisplayString() }
{% endif %}
write !, "--- END PRODUCTION SETUP ---"
halt
