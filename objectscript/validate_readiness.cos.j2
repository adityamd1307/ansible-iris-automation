; =====================================================================
; Read-only node readiness validation -> emits single-line JSON
; =====================================================================
; Rendered by playbooks/validate_nodes.yml. Verifies the namespace,
; databases and web application exist, and reports interoperability
; production status (auto-start configured + running). Strictly
; read-only; never reports as changed.
;
; Production status is mirror-role aware: the primary must have auto-start
; and a running production; the backup must have the mirrored production
; class and Ens.Config.Production object (not a separate SetAutoStart call).
;
; Execution notes:
;  - Every line is a single complete statement. `iris session` reads
;    stdin as a terminal REPL and cannot continue a { } block across
;    input lines, so the guarded interop probe is a single-line try.
;  - The result is emitted as ONE line "READINESS_JSON:{...}" so the
;    playbook can extract it without fragile multi-line regex.
zn "%SYS"
set q=$char(34)
set nsExists=##class(%SYS.Namespace).Exists("{{ namespace }}")
set glbExists=##class(SYS.Database).%ExistsId("{{ databases[0].directory }}/")
set rtnExists=##class(SYS.Database).%ExistsId("{{ databases[1].directory }}/")
set appExists=##class(Security.Applications).Exists("{{ web_apps[0].path }}")
set interopAvailable=0,prodAutoStart="",prodClassExists=0,prodConfigExists=0,prodConfigured=0,prodRunning=0
set desired="{{ production.class | default('') }}"
try { zn "{{ namespace }}" set hasEns=##class(%Dictionary.CompiledClass).%ExistsId("Ens.Director") if hasEns { set interopAvailable=1 set prodClassExists=##class(%Dictionary.CompiledClass).%ExistsId(desired) set prodConfigExists=##class(Ens.Config.Production).%ExistsId(desired) set prodAutoStart=##class(Ens.Director).GetActiveProductionName() set prodRunning=##class(Ens.Director).IsProductionRunning() {% if mirror_role | default('') == 'backup' %} set prodConfigured=(prodClassExists&prodConfigExists) {% else %} set prodConfigured=(prodAutoStart=desired) {% endif %} } zn "%SYS" } catch e { set prodRunning=0 }
set j="{"
set j=j_q_"node"_q_":"_q_$System.INetInfo.LocalHostName()_q_","
set j=j_q_"namespace"_q_":"_q_"{{ namespace }}"_q_","
set j=j_q_"mirror_role"_q_":"_q_"{{ mirror_role | default('unknown') }}"_q_","
set j=j_q_"namespace_exists"_q_":"_$select(nsExists:"true",1:"false")_","
set j=j_q_"interop_available"_q_":"_$select(interopAvailable:"true",1:"false")_","
set j=j_q_"globals_db_exists"_q_":"_$select(glbExists:"true",1:"false")_","
set j=j_q_"routines_db_exists"_q_":"_$select(rtnExists:"true",1:"false")_","
set j=j_q_"web_app_exists"_q_":"_$select(appExists:"true",1:"false")_","
set j=j_q_"production_autostart"_q_":"_q_prodAutoStart_q_","
set j=j_q_"production_class_exists"_q_":"_$select(prodClassExists:"true",1:"false")_","
set j=j_q_"production_config_exists"_q_":"_$select(prodConfigExists:"true",1:"false")_","
set j=j_q_"production_configured"_q_":"_$select(prodConfigured:"true",1:"false")_","
set j=j_q_"production_running"_q_":"_$select(prodRunning:"true",1:"false")
set j=j_"}"
write !,"READINESS_JSON:"_j
halt
