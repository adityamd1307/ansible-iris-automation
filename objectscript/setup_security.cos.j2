; =====================================================================
; Guarded / idempotent security setup (Layer 2 — bootstrap on every node)
; =====================================================================
; Rendered by playbooks/setup_security.yml on iris_nodes.
;
; What this does:
;   - Enables IRIS services if present (idempotent Security.Services)
;   - Creates application roles if missing (idempotent Security.Roles)
;   - Optionally rotates the admin password (only when rotate_admin_password
;     is true; session runs with no_log; script deleted after execution)
;
; What this does NOT do:
;   - Replicate IRISSECURITY to the backup — mirroring skips that database.
;     Use sync_security.yml (Security.* Export/Import) for primary→backup sync.
;
; Prerequisites:
;   - setup_databases.yml must have run first — roles reference %DB_<name>
;     resources created there (otherwise #892 Resource does not exist).
;
; Run inside %SYS. Every line is a single complete statement so it executes
; correctly through `iris session` (the terminal has no multi-line blocks).
;
; NOTE: Service enablement is done here in guarded ObjectScript, NOT via CPF
; merge. A configuration merge has no services section in this IRIS version
; (an [%Service_*] / [Services] section is rejected with ERROR #415), so
; Security.Services is the correct mechanism. See docs/mechanism-mapping.md.
zn "%SYS"
write !, "--- SECURITY SETUP ---"
{% for svc in security_services | default([]) %}
; Skip unknown services (e.g. legacy %Service_CSP) rather than failing the run.
if '##class(Security.Services).Exists("{{ svc.name }}") { write !,"SKIP SERVICE {{ svc.name }} not-present" } else { kill sp do ##class(Security.Services).Get("{{ svc.name }}",.sp) if +$get(sp("Enabled"))={{ 1 if svc.enabled | default(true) else 0 }} { write !,"EXISTS SERVICE {{ svc.name }}" } else { set sp("Enabled")={{ 1 if svc.enabled | default(true) else 0 }} set sc=##class(Security.Services).Modify("{{ svc.name }}",.sp) write !,"CHANGED SERVICE {{ svc.name }} sc="_$system.Status.GetErrorText(sc) } }
{% endfor %}
{% for role in security_roles %}
; Create if missing; EXISTS ROLE on re-run proves idempotency for demos.
if '##class(Security.Roles).Exists("{{ role.name }}") { set sc=##class(Security.Roles).Create("{{ role.name }}","{{ role.description | default('') }}","{{ role.resources | default('') }}") write !,"CREATED ROLE {{ role.name }} sc="_$system.Status.GetErrorText(sc) } else { set sc=##class(Security.Roles).Modify("{{ role.name }}",.props) write !,"EXISTS ROLE {{ role.name }}" }
{% endfor %}
{% if rotate_admin_password | default(false) %}
; Password from ansible-vault — never commit vault.yml; this file is deleted after run.
kill up set up("Password")="{{ vault_iris_admin_password }}" set sc=##class(Security.Users).Modify("{{ admin_user | default('_SYSTEM') }}",.up) write !,"PWROTATE {{ admin_user | default('_SYSTEM') }} sc="_$system.Status.GetErrorText(sc)
{% endif %}
write !, "--- END SECURITY SETUP ---"
halt
