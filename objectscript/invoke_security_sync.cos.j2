; =====================================================================
; Thin invoke script for SecuritySync.Service (one statement per line)
; =====================================================================
; Rendered by sync_security.yml / validate_security_sync.yml via push_file.
; Ansible sets security_sync_action per run; only one action executes.
;
; Actions (see SecuritySync.Service):
;   export           — primary: Security.Roles/Users Export → XML paths in cfg
;   import           — backup: real import (Flags=0), then post-import validate
;   dry_run_import   — backup: Import with Flags=1 (count/validate only, no mutate)
;   validate         — read-only: required roles/users + live counts → JSON
;   create_test_delta — primary E2E: SYNC_TEST_ROLE, sync_test_user, bump TRAINING_APP
;
; Output: SecuritySync.Service always writes one line:
;   SECURITY_SYNC_JSON:{...}
; Playbooks select that line and parse with from_json (see mechanism-mapping.md).
;
; Config paths and required lists come from inventory security_sync_* vars.
zn "%SYS"
{% set roles_path = security_sync_roles_path | default('/tmp/iris_security_roles.xml') %}
{% set users_path = security_sync_users_path | default('/tmp/iris_security_users.xml') %}
{% set include_sql = 1 if security_sync_include_sql_privileges | default(false) | bool else 0 %}
{% set req_roles = (security_sync_required_roles | default([])) | join(',') %}
{% set req_users = (security_sync_required_users | default([])) | join(',') %}
set cfg=##class(SecuritySync.Config).Default() set cfg.RolesPath="{{ roles_path }}" set cfg.UsersPath="{{ users_path }}" set cfg.IncludeSQLPrivileges={{ include_sql }} set cfg.RequiredRoles="{{ req_roles }}" set cfg.RequiredUsers="{{ req_users }}"
{% if security_sync_action == 'export' %}
do ##class(SecuritySync.Service).RunExport(cfg)
{% elif security_sync_action == 'import' %}
do ##class(SecuritySync.Service).RunImport(cfg)
{% elif security_sync_action == 'dry_run_import' %}
do ##class(SecuritySync.Service).DryRunImport(cfg)
{% elif security_sync_action == 'validate' %}
do ##class(SecuritySync.Service).RunValidate(cfg)
{% elif security_sync_action == 'create_test_delta' %}
do ##class(SecuritySync.Service).CreateTestDelta()
{% else %}
write !,"SECURITY_SYNC_JSON:{""ok"":false,""step"":""invoke"",""errors"":[""Unknown security_sync_action: {{ security_sync_action }}""]}"
{% endif %}
halt
