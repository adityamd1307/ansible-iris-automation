; =====================================================================
; Guarded mirror primary setup
; =====================================================================
; Creates/starts the mirror set on the primary and marks configured
; databases as mirrored. Run on iris_primary before backup join;
; AddFailoverMember runs later via setup_mirror_primary_add_failover.cos.j2.
zn "%SYS"
write !, "--- MIRROR PRIMARY SETUP ---"
set mirror="{{ mirror_name }}"
set member=$SYSTEM.Mirror.GetMemberType()
if member="Not Member" { set sc=##class(SYS.Mirror).CreateNewMirrorSet(mirror,"{{ inventory_hostname }}",.mirrorInfo,.sslInfo) write !,"CREATE MIRROR "_mirror_" sc="_$system.Status.GetErrorText(sc) } else { write !,"EXISTS MIRROR MEMBER type="_member }
if '##class(SYS.Mirror).IsMirrorStarted(mirror) { set sc=##class(SYS.Mirror).StartMirror(mirror) write !,"START MIRROR "_mirror_" sc="_$system.Status.GetErrorText(sc) } else { write !,"EXISTS MIRROR STARTED "_mirror }
if $SYSTEM.Mirror.IsPrimary() { write !,"EXISTS PRIMARY" } else { write !,"ROLE DRIFT expected primary but this member is not primary - leaving mirror role unchanged" halt }
{% for db in mirror_databases | default([]) %}
{% set db_item = (databases | selectattr('name','equalto',db) | list | first) %}
{% if db_item is defined %}
set sc=##class(SYS.Mirror).AddDatabase("{{ db_item.directory }}/","{{ db }}",1) set err=$system.Status.GetErrorText(sc) write !,$select(err["ERROR #2063":"EXISTS DATABASE {{ db }}",1:"ADD DATABASE {{ db }} sc="_err)
{% endif %}
{% endfor %}
write !, "--- END MIRROR PRIMARY SETUP ---"
halt
